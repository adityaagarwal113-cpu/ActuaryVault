rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /questions/{questionId} {
      allow read: if true;
      allow write: if true; // Allow all for prototype admin actions, secure in production
    }
    match /favorites/{favoriteId} {
      allow read, write: if true; // Allow user storage bookmarks
    }
  }
}
